# App
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://foorest:foorest_dev@localhost:5432/foorest

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SNS_PHONE_ORIGINATION_NUMBER=+15551234567

# Feature Flags (set to false for local dev — OTP logged to console instead)
AWS_SNS_ENABLED=false
